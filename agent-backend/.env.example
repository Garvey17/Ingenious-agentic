# ============================================
# Deep Research Desk - Environment Configuration
# ============================================

# Application Settings
# --------------------
APP_NAME="Deep Research Desk"
APP_VERSION="0.1.0"
ENVIRONMENT="development"  # development, staging, production
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# API Server
# ----------
HOST="0.0.0.0"
PORT=8000
RELOAD=true  # Auto-reload on code changes (development only)

# LLM Provider Configuration
# ---------------------------
# Options: "openai" or "gemini"
LLM_PROVIDER="gemini"

# OpenAI Configuration
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL="gpt-4-turbo-preview"
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# Google Gemini Configuration
GOOGLE_API_KEY='AIzaSyDyXQK-W9V0oF9tb-BfreQn8noPT5KJLOA'
GEMINI_MODEL="gemini-1.5-pro"
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=4096

# Embedding Models
# ----------------
EMBEDDING_PROVIDER="gemini"  # openai or gemini
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
GEMINI_EMBEDDING_MODEL="models/embedding-001"

# Web Search Tool
# ---------------
# Options: "tavily", "serper", "placeholder"
SEARCH_PROVIDER="tavily"
TAVILY_API_KEY='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'
SERPER_API_KEY="your-serper-api-key-here"

# Vector Database (Qdrant)
# ------------------------
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_API_KEY=""  # Optional, for Qdrant Cloud
QDRANT_COLLECTION_NAME="research_memory"
QDRANT_VECTOR_SIZE=1536  # Must match embedding model dimension

# Memory Configuration
# --------------------
ENABLE_MEMORY=false  # Enable/disable vector memory (Phase 3)
MEMORY_TOP_K=5  # Number of relevant memories to retrieve

# Agent Configuration
# -------------------
MAX_ITERATIONS=3  # Maximum research-analyze-write loops
CRITIC_THRESHOLD=7.0  # Minimum quality score (0-10) to accept report

# CORS Settings
# -------------
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"  # Comma-separated

# Rate Limiting
# -------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10

# Logging
# -------
LOG_FORMAT="json"  # json or console
LOG_FILE_ENABLED=false
LOG_FILE_PATH="logs/app.log"
