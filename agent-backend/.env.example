# ============================================
# Ingenious Agentic - Environment Configuration
# Copy this file to .env and fill in your keys
# ============================================

# Application Settings
APP_NAME="Ingenious Agentic"
APP_VERSION="0.1.0"
ENVIRONMENT="development"   # development | staging | production
LOG_LEVEL="INFO"            # DEBUG | INFO | WARNING | ERROR | CRITICAL

# API Server
HOST="0.0.0.0"
PORT=8000

# -----------------------------------------------
# LLM Provider  (default: openai)
# -----------------------------------------------
LLM_PROVIDER="openai"       # openai | gemini

# OpenAI (primary — required when LLM_PROVIDER=openai)
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL="gpt-4-turbo-preview"
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# Google Gemini (optional — only needed when LLM_PROVIDER=gemini)
GOOGLE_API_KEY="your-google-api-key-here"
GEMINI_MODEL="gemini-1.5-pro"
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=4096

# -----------------------------------------------
# Embedding Models  (default: openai)
# -----------------------------------------------
EMBEDDING_PROVIDER="openai"            # openai | gemini
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
GEMINI_EMBEDDING_MODEL="models/embedding-001"

# -----------------------------------------------
# Web Search Tool
# -----------------------------------------------
# Options: "tavily" | "placeholder" (placeholder needs no API key)
SEARCH_PROVIDER="tavily"
TAVILY_API_KEY="your-tavily-api-key-here"

# -----------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_API_KEY=""              # Leave blank for local Docker; fill in for Qdrant Cloud
QDRANT_COLLECTION_NAME="research_memory"
QDRANT_VECTOR_SIZE=1536        # Must match the embedding model output dimension

# -----------------------------------------------
# Memory Configuration
# -----------------------------------------------
ENABLE_MEMORY=false            # Set to true to enable Qdrant vector memory
MEMORY_TOP_K=5                 # How many past research results to inject into planner

# -----------------------------------------------
# Agent Behaviour
# -----------------------------------------------
MAX_ITERATIONS=3               # Max revision loops before the Critic force-approves
CRITIC_THRESHOLD=7.0           # Minimum quality score (0-10) to auto-approve a report

# -----------------------------------------------
# CORS
# -----------------------------------------------
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
